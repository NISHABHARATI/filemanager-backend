    {
      "name": "Share Links",
      "item": [
        {
          "name": "Create Share Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set(\"shareLinkId\", String(json.id));",
                  "}",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set(\"shareToken\", String(json.token));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "userId",
                "value": "{{userId}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemId\": {{shareItemId}},\n  \"expiresAt\": \"{{shareExpiresAt}}\",\n  \"password\": \"{{sharePassword}}\",\n  \"maxDownloads\": {{shareMaxDownloads}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/share-links",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "share-links"
              ]
            }
          },
          "response": []
        },
